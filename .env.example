# Template of every env var the bot/signer read. Copy to `.env` (gitignored) and fill.
# NEVER put a private key or a real secret in a committed file. Tokens are referenced by the
# *_env names declared in infra/config/providers.toml.

# --- Config / paths ---
ARBIT_CONFIG_DIR=infra/config
ARBIT_HOT_KEYPAIR=secrets/hot-keypair.json
ARBIT_KILL_SWITCH=secrets/kill_switch

# --- JSON-RPC / WSS (Chainstack Solana Global Node; tier=first_profit) ---
# The secret is IN the URL (key-in-path), NOT a header — paste the full endpoint from the
# Chainstack console (Node -> Access & credentials). These OVERRIDE the public json_rpc/
# fallback_wss in infra/config/providers.toml when set. Leave blank to stay on public RPC.
#   e.g. CHAINSTACK_SOLANA_RPC_URL=https://nd-123-456-789.p2pify.com/<KEY>
#        CHAINSTACK_SOLANA_WSS_URL=wss://ws-nd-123-456-789.p2pify.com/<KEY>
CHAINSTACK_SOLANA_RPC_URL=
CHAINSTACK_SOLANA_WSS_URL=

# --- Data source (Chainstack Yellowstone gRPC add-on; tier=first_profit) ---
# gRPC auth IS a header token (x-token), unlike the URL-embedded JSON-RPC secret above.
CHAINSTACK_GRPC_TOKEN=

# --- Landing (Jito Block Engine) ---
JITO_AUTH_UUID=

# --- Logging ---
RUST_LOG=info
