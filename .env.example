# Template of every env var the bot/signer read. Copy to `.env` (gitignored) and fill.
# NEVER put a private key or a real secret in a committed file. Tokens are referenced by the
# *_env names declared in infra/config/providers.toml.

# --- Config / paths ---
ARBIT_CONFIG_DIR=infra/config
ARBIT_HOT_KEYPAIR=secrets/hot-keypair.json
ARBIT_KILL_SWITCH=secrets/kill_switch

# --- JSON-RPC / WSS (Chainstack Solana Global Node; tier=first_profit) ---
# A Chainstack node exposes TWO credential sets for the SAME node (docs: "authentication methods
# for different scenarios"); pick ONE auth form and fill the matching vars below. Bearer is NOT
# available for node APIs.
#   (A) key-in-path : RPC/WSS carry the secret in the URL path; leave USERNAME/PASSWORD blank.
#         CHAINSTACK_SOLANA_RPC_URL=https://nd-123-456-789.p2pify.com/<KEY>
#         CHAINSTACK_SOLANA_WSS_URL=wss://ws-nd-123-456-789.p2pify.com/<KEY>
#   (B) basic-auth  : RPC/WSS are a BARE host; auth comes from USERNAME/PASSWORD below.
#         CHAINSTACK_SOLANA_RPC_URL=https://solana-mainnet.core.chainstack.com   <- bare host, no key
#         CHAINSTACK_SOLANA_WSS_URL=wss://solana-mainnet.core.chainstack.com
# These OVERRIDE the public json_rpc/fallback_wss in providers.toml when set; blank ⇒ public RPC.
CHAINSTACK_SOLANA_RPC_URL=
CHAINSTACK_SOLANA_WSS_URL=

# Basic-Auth credentials (form B). REQUIRED when *_RPC_URL is a bare host — without them a bare-host
# endpoint returns 401. The client applies them as `Authorization: Basic` (DataSourceConfig::
# resolve_basic_auth, named by providers.toml basic_auth_*_env). For Surfpool/curl, embed instead:
# `--rpc-url https://${CHAINSTACK_USERNAME}:${CHAINSTACK_PASSWORD}@<bare-host>` (mind .env CRLF: tr -d '\r').
# Leave blank for form A (key-in-path).
CHAINSTACK_USERNAME=
CHAINSTACK_PASSWORD=

# --- Data source (Chainstack Yellowstone gRPC add-on; tier=first_profit) ---
# gRPC auth IS the x-token METADATA header (NOT URL-embedded, NOT Basic Auth — that's tutorial-only).
# The gRPC host (<chain>-mainnet.core.chainstack.com:443) is separate from the JSON-RPC endpoint and
# is console-only; it overrides the placeholder in providers.toml via grpc.url_env. Both required
# for the first_profit tier (validated by `make config-check`).
#   e.g. CHAINSTACK_GRPC_URL=solana-mainnet.core.chainstack.com:443   (port 443; exact host from console)
CHAINSTACK_GRPC_URL=
CHAINSTACK_GRPC_TOKEN=

# --- Landing (Jito Block Engine) ---
JITO_AUTH_UUID=

# --- Logging ---
RUST_LOG=info
